# Public booking UI → Nest API (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000

# PayPal public client ID (sandbox or live from developer.paypal.com).
# Server-side secret belongs in backend .env as PAYPAL_CLIENT_SECRET — never here.
# VITE_PAYPAL_CLIENT_ID=
# PayPal button/checkout locale (default en_US → 46.00 EUR; es_ES → 46,00 EUR).
# VITE_PAYPAL_LOCALE=en_US

# Stripe publishable key (pk_test_... or pk_live_...)
# VITE_STRIPE_PUBLISHABLE_KEY=

# Hostinger (Apache): upload the full `dist/` output including `.htaccess` from `public/`
# so routes like `/admin`, `/booking/details`, `/booking/payment`, `/booking/success`
# load `index.html` instead of “page does not exist”.

# Optional: site used in reservation modal QR + display (no trailing slash)
# VITE_PUBLIC_BOOKING_SITE_URL=https://www.taxibarcelona24.com

# Nav contact links (email + WhatsApp phone, e.g. +34663619000)
# VITE_CONTACT_EMAIL=info@barcelonataxi24.com
# VITE_CONTACT_WHATSAPP=+34663619000
